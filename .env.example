# PostgreSQL（生产环境取消注释）
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emotion_diary

# JWT
JWT_SECRET=change-me-in-production

# ── 大模型配置 ─────────────────────────────────────────────────────────
# 可选值: openai | ollama | deepseek | openai-compat | none
LLM_PROVIDER=openai

# OpenAI API Key（使用 OpenAI 时必填）
LLM_API_KEY=sk-your-key-here

# 模型名称（可选，默认 gpt-4o-mini）
# LLM_MODEL=gpt-4o-mini

# 自定义 API 地址（可选，使用代理或其他兼容服务时设置）
# LLM_BASE_URL=https://api.openai.com/v1
